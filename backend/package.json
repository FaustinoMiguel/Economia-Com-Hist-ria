{
  "name": "economia-com-historia-backend",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev":   "tsx watch --env-file=.env.desenvolvimento src/server.ts",
    "start": "tsx watch --env-file=.env.final src/server.ts",
    "build": "tsc -p tsconfig.json",
    "serve": "node --env-file=.env.final dist/server.js"
  },
  "dependencies": {
    "bcryptjs":     "^3.0.2",
    "cors":         "^2.8.5",
    "dotenv":       "^17.2.1",
    "express":      "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2":       "^3.14.3",
    "nodemailer":   "^6.10.1"
  },
  "devDependencies": {
    "@types/bcryptjs":     "^2.4.6",
    "@types/cors":         "^2.8.19",
    "@types/express":      "^5.0.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/nodemailer":   "^6.4.17",
    "@types/node":         "^24.3.0",
    "tsx":                 "^4.20.5",
    "typescript":          "^5.9.2"
  }
}
